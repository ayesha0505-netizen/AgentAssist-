# Google Gemini API Key (Required for ReAct Agent reasoning and generation)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# JWT Authentication Secret Key & Algorithm
JWT_SECRET=super-secret-jwt-key-change-in-production-2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Connection URL (SQLite by default)
DATABASE_URL=sqlite:///./agentassist.db

# RAG Configuration
VECTOR_STORE_PATH=./vector_store
KNOWLEDGE_BASE_PATH=./knowledge_base
RAG_SIMILARITY_THRESHOLD=0.72
RAG_TOP_K=3
